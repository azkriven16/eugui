{
  "name": "@complib/cli",
  "version": "0.1.0",
  "description": "A shadcn-style CLI for distributing component libraries",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "bin": { "complib": "./bin/index.dev.mjs" },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "./package.json": "./package.json"
    },
    "bin": { "complib": "./bin/index.mjs" }
  },
  "files": ["bin", "dist"],
  "keywords": ["cli", "components", "shadcn", "tailwind", "react", "ui", "copy-paste", "registry"],
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/component-library-cli.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/YOUR_USERNAME/component-library-cli#readme",
  "bugs": "https://github.com/YOUR_USERNAME/component-library-cli/issues",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc",
    "test": "vitest",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "chalk": "^5.0.0",
    "commander": "^14.0.0",
    "execa": "^9.0.0",
    "ts-morph": "^20.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.10.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
